    @import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=IBM+Plex+Mono:wght@400;600&display=swap');
    *{box-sizing:border-box}
    .pill{border:1px solid #1a2535;background:transparent;color:#475569;padding:5px 10px;border-radius:999px;cursor:pointer;font-family:'IBM Plex Mono',monospace;font-size:10px;transition:all .2s}
