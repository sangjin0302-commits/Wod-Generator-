    .lvl{border:1px solid;padding:5px 12px;border-radius:6px;cursor:pointer;font-family:'Bebas Neue',monospace;font-size:16px;transition:all .2s;background:transparent}
    .card{background:#0d1626;border:1px solid #1a2535;border-radius:12px;padding:12px}
    .gen{width:100%;padding:12px;border:none;border-radius:8px;color:#fff;font-family:'Bebas Neue',monospace;font-size:20px;letter-spacing:.15em;cursor:pointer;transition:all .2s}
    .gen:hover:not(:disabled){filter:brightness(1.15);transform:translateY(-1px)}.gen:disabled{opacity:.3;cursor:not-allowed}
    .rbadge{color:#fff;font-family:'Bebas Neue';font-size:17px;min-width:34px;height:34px;border-radius:6px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .sharebtn{display:flex;align-items:center;gap:4px;padding:5px 10px;background:transparent;border:1px solid #1a2535;border-radius:6px;color:#475569;font-family:'IBM Plex Mono',monospace;font-size:10px;cursor:pointer;transition:all .2s}
    .sharebtn:hover,.sharebtn.ok{border-color:#22c55e;color:#22c55e}.sharebtn.ok{background:#052e16}
    .tab{flex:1;padding:8px;border:none;background:transparent;color:#334155;font-family:'IBM Plex Mono',monospace;font-size:10px;cursor:pointer;transition:all .2s;border-bottom:2px solid transparent}
    .tab.on{color:#ef4444;border-bottom-color:#ef4444}
    .tag{font-size:9px;background:#0d1626;color:#334155;padding:2px 5px;border-radius:999px;border:1px solid #1a2535}
    .mrow{padding:8px 0;border-bottom:1px solid #1a2535;display:flex;align-items:center;gap:8px}.mrow:last-child{border-bottom:none}
    .rinp{width:42px;background:#1a2535;border:1px solid #253347;border-radius:5px;color:#e2e8f0;font-family:'IBM Plex Mono',monospace;font-size:10px;padding:3px 4px;text-align:center}
