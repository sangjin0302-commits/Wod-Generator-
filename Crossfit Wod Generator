// ─────────────────────────────────────────────────────
// 헬퍼
// ─────────────────────────────────────────────────────
function getMovementForLevel(cat,lk){const c=MOVEMENTS[cat];const idx=Math.min(LEVEL_INDEX[lk],c.levels.length-1);return{name:c.levels[idx],weight_M:c.weights.M[idx],weight_F:c.weights.F[idx],muscles:c.muscles,category:cat};}
function buildWOD(movements,wodType,level,time,rationale,rounds,extra){return{movements,muscles:[...new Set(movements.flatMap(m=>m.muscles))],wodType,level,time,rationale,rounds,extra};}
function encodeWOD(wod){const p={t:wod.wodType,l:wod.level,m:wod.time,mv:wod.movements.map(m=>({n:m.name,r:m.reps,wm:m.weight_M??m.wM,wf:m.weight_F??m.wF,ms:m.muscles,c:m.category})),ra:wod.rationale,ro:wod.rounds,ex:wod.extra};return btoa(encodeURIComponent(JSON.stringify(p)));}
function decodeWOD(str){try{const p=JSON.parse(decodeURIComponent(atob(str)));const movements=p.mv.map(({c,n,r,wm,wf,ms})=>c&&MOVEMENTS[c]?{...getMovementForLevel(c,p.l),reps:r}:{name:n,reps:r,weight_M:wm,weight_F:wf,muscles:ms||[]});return buildWOD(movements,p.t,p.l,p.m,p.ra,p.ro,p.ex);}catch{return null;}}

// ─────────────────────────────────────────────────────
// AI 생성
// ─────────────────────────────────────────────────────
async function generateWithAI(wodType,level,time,targetRegions,rounds){
  const avail=Object.entries(MOVEMENTS).map(([cat,info])=>{const idx=Math.min(LEVEL_INDEX[level],info.levels.length-1);return`"${cat}":${info.levels[idx]}|근육:${info.muscles.join(",")}|M:${info.weights.M[idx]||"없음"}/F:${info.weights.F[idx]||"없음"}`;}).join("\n");
  const ref=NAMED_WODS.slice(0,15).map(w=>`${w.name}(${w.type}${w.rounds?"/"+w.rounds:""}): ${w.movements.map(m=>`${m.reps!=null?m.reps+"×":""}${m.name}`).join("+")} `).join("\n");
  const regionStr=targetRegions.includes("전신")?"전신 균형":`${targetRegions.join("+")} 집중`;
  const isDB=wodType==="Death by",isFL=wodType==="For Load",isTab=wodType==="Tabata",isFT=wodType==="For Time";
  const mc=isDB?2:isTab?2:isFL?1:wodType==="EMOM"?3:Math.floor(Math.random()*3)+3;
  const tg=isFL?"동작1개 reps=null 최대중량":isTab?"동작1~2개 reps=null 20s/10s×8":isDB?"[0]=고정(reps설정) [1]=증가(reps=1)":isFT?`${rounds}R 동작${mc}개 라운드당9~21개`:wodType==="AMRAP"?`${time}분 동작3개 5~10개`:`EMOM ${time}분 동작3개 5~8개`;
  const prompt=`크로스핏 전문 코치. JSON만 응답(코드블록없이).
타입:${wodType}|레벨:${level}|부위:${regionStr}|${tg}
참고 와드:\n${ref}
동작:\n${avail}
원칙:같은주동근연속금지|${level==="RXD"?"올림픽리프팅가능":level==="A"?"중간난이도":level==="B"?"기본위주":"바디웨이트만"}
{"movements":[{"category":"키","reps":숫자또는null}],"rationale":"한국어 2문장"}`;
  const res=await fetch("https://api.anthropic.com/v1/messages",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify({model:"claude-sonnet-4-20250514",max_tokens:600,messages:[{role:"user",content:prompt}]})});
  const data=await res.json();
  const text=data.content.map(b=>b.text||"").join("").replace(/```json|```/g,"").trim();
  const parsed=JSON.parse(text);
  const movements=parsed.movements.map(({category,reps})=>({...getMovementForLevel(category,level),reps}));
  const extra=isDB?{deathByFixed:{name:movements[0]?.name,reps:movements[0]?.reps}}:isFL?{forLoad:true}:isTab?{tabata:true}:null;
  return buildWOD(movements,wodType,level,time,parsed.rationale,rounds,extra);
}

