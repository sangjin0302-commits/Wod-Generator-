export default function WODGenerator(){
  const [mode,setMode]         =useState("ai");
  const [wodType,setWodType]   =useState("For Time");
  const [level,setLevel]       =useState("RXD");
  const [time,setTime]         =useState(15);
  const [rounds,setRounds]     =useState(5);
  const [regions,setRegions]   =useState(["전신"]);
  const [wod,setWod]           =useState(null);
  const [loading,setLoading]   =useState(false);
  const [error,setError]       =useState(null);
  const [copied,setCopied]     =useState(false);
  const [selCats,setSelCats]   =useState([]);
  const [manReps,setManReps]   =useState({});
  const [showRat,setShowRat]   =useState(false);
  const [namedIdx,setNamedIdx] =useState(null);
  const [catFilter,setCatFilter]=useState("전체");
  const [srch,setSrch]         =useState("");

  useEffect(()=>{const h=window.location.hash.replace("#","");if(h){const d=decodeWOD(h);if(d){setWod(d);setWodType(d.wodType);setLevel(d.level);if(d.time)setTime(d.time);}}},[]);

  const toggleRegion=r=>{if(r==="전신"){setRegions(["전신"]);return;}setRegions(prev=>{const w=prev.filter(x=>x!=="전신");const n=w.includes(r)?w.filter(x=>x!==r):[...w,r];return n.length===0?["전신"]:n;});};
  const toggleCat=c=>setSelCats(p=>p.includes(c)?p.filter(x=>x!==c):[...p,c]);

  const isNamed=wodType==="네임드 와드",isFL=wodType==="For Load",isTab=wodType==="Tabata",isDB=wodType==="Death by",isFT=wodType==="For Time";

  const filteredNamed=NAMED_WODS.filter(w=>(catFilter==="전체"||w.cat===catFilter)&&(srch===""||w.name.toLowerCase().includes(srch.toLowerCase())));
  const girlsN=NAMED_WODS.filter(w=>w.cat==="Girls").length;
  const heroN=NAMED_WODS.filter(w=>w.cat==="Hero").length;
  const openN=NAMED_WODS.filter(w=>w.cat==="Open").length;

  const handleGenerate=useCallback(async()=>{
    setError(null);setShowRat(false);
    if(isNamed){
      if(namedIdx===null){setError("와드를 선택해주세요.");return;}
      const nw=NAMED_WODS[namedIdx];
      const mvs=nw.movements.map(m=>({name:m.name,reps:m.reps,weight_M:m.wM,weight_F:m.wF,muscles:m.muscles}));
      const w=buildWOD(mvs,nw.type,null,nw.time,nw.note,nw.rounds,null);
      w.namedTitle=nw.name;w.namedDesc=nw.desc;w.tribute=nw.tribute;w.category=nw.cat;
      setWod(w);return;
    }
    if(mode==="ai"){
      setLoading(true);
      try{setWod(await generateWithAI(wodType,level,time,regions,rounds));}
      catch(e){console.error(e);setError("AI 생성 실패. 다시 시도해주세요.");}
      finally{setLoading(false);}
    }else{
      if(!selCats.length)return;
      const REPS=[5,7,9,10,12,15,21];
      const cnt=isDB?2:Math.min(selCats.length,isTab?2:isFL?1:wodType==="EMOM"?3:5);
      const movements=selCats.slice(0,cnt).map(cat=>({...getMovementForLevel(cat,level),reps:(isFL||isTab)?null:(parseInt(manReps[cat])||REPS[Math.floor(Math.random()*REPS.length)])}));
      const extra=isDB?{deathByFixed:{name:movements[0]?.name,reps:movements[0]?.reps}}:isFL?{forLoad:true}:isTab?{tabata:true}:null;
      setWod(buildWOD(movements,wodType,level,time,null,rounds,extra));
    }
  },[mode,wodType,level,time,regions,rounds,selCats,manReps,namedIdx,isNamed,isDB,isFL,isTab]);

  const handleShare=()=>{if(!wod)return;navigator.clipboard.writeText(`${window.location.origin}${window.location.pathname}#${encodeWOD(wod)}`).then(()=>{setCopied(true);setTimeout(()=>setCopied(false),2500);});};

  const cc=w=>CAT_COLOR[w]||CAT_COLOR.Girls;

  return(<div style={{minHeight:"100vh",background:"#070d1a",color:"#e2e8f0",fontFamily:"'Courier New',monospace",padding:"16px 12px"}}>
