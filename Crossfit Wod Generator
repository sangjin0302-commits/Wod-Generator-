          <input className="srch" placeholder="와드 검색..." value={srch} onChange={e=>setSrch(e.target.value)}/>
        </div>
        <div style={{display:"grid",gridTemplateColumns:"repeat(auto-fill,minmax(120px,1fr))",gap:4,maxHeight:320,overflowY:"auto"}}>
          {filteredNamed.map(nw=>{
            const realIdx=NAMED_WODS.indexOf(nw);
            return(<button key={nw.name} className={`nc ${namedIdx===realIdx?"on":""}`} onClick={()=>setNamedIdx(realIdx)}>
              <div style={{display:"flex",justifyContent:"space-between",alignItems:"center"}}>
                <span style={{fontFamily:"'Bebas Neue'",fontSize:14,color:namedIdx===realIdx?"#a855f7":"#475569",letterSpacing:".04em"}}>{nw.name}</span>
                <span style={{fontSize:8,borderRadius:3,padding:"1px 4px",border:"1px solid",background:cc(nw.cat).bg,color:cc(nw.cat).text,borderColor:cc(nw.cat).border}}>{nw.cat}</span>
              </div>
              <div style={{fontSize:8,color:"#253347",marginTop:1}}>{nw.type}{nw.rounds?` · ${typeof nw.rounds==="string"?nw.rounds:nw.rounds+"R"}`:""}{nw.time?` · ${nw.time}분`:""}</div>
            </button>);
          })}
        </div>
      </div>
    )}

    {/* AI 옵션 */}
    {mode==="ai"&&!isNamed&&(
      <div style={{display:"grid",gridTemplateColumns:"1fr 1fr",gap:8,marginBottom:8}}>
        <div className="card">
          <div style={{fontSize:8,color:"#253347",letterSpacing:".2em",marginBottom:6}}>시간 (분)</div>
          <div style={{display:"flex",gap:4,flexWrap:"wrap",opacity:(isTab||isFL)?.25:1}}>
            {TIME_OPTIONS.map(t=><button key={t} className={`pill ${time===t?"on":""}`} onClick={()=>setTime(t)} disabled={isTab||isFL}>{t}</button>)}
          </div>
          {isFT&&(<div style={{marginTop:7,borderTop:"1px solid #1a2535",paddingTop:6}}>
            <div style={{fontSize:8,color:"#253347",letterSpacing:".2em",marginBottom:5}}>라운드 수</div>
            <div style={{display:"flex",gap:4}}>{ROUNDS_OPT.map(r=><button key={r} className={`pill ${rounds===r?"on":""}`} onClick={()=>setRounds(r)}>{r}R</button>)}</div>
          </div>)}
        </div>
        <div className="card">
          <div style={{fontSize:8,color:"#253347",letterSpacing:".2em",marginBottom:6}}>목표 부위</div>
          <div style={{display:"flex",flexWrap:"wrap",gap:4}}>
            {BODY_REGIONS.map(r=><button key={r} className={`pill ${regions.includes(r)?"on":""}`} onClick={()=>toggleRegion(r)}>{r}</button>)}
          </div>
        </div>
      </div>
    )}

    {/* 직접 선택 */}
    {mode==="manual"&&!isNamed&&(
      <div className="card" style={{marginBottom:8}}>
        <div style={{fontSize:8,color:"#253347",letterSpacing:".2em",marginBottom:7}}>동작 선택 {selCats.length>0&&<span style={{color:"#ef4444"}}>({selCats.length}개)</span>}</div>
        <div style={{display:"flex",flexWrap:"wrap",gap:4}}>
          {Object.entries(MOVEMENTS).map(([cat,info])=>{const on=selCats.includes(cat);return(<button key={cat} className={`pill ${on?"sel":""}`} onClick={()=>toggleCat(cat)} style={{display:"flex",flexDirection:"column",alignItems:"flex-start",borderRadius:7,padding:"5px 9px",borderColor:on?"#334155":"#1a2535",color:on?"#e2e8f0":"#334155"}}><span style={{fontWeight:600,fontSize:10}}>{info.label}</span><span style={{fontSize:8,color:"#253347",marginTop:1}}>{getMovementForLevel(cat,level).name}</span></button>);})}
        </div>
        {isFT&&(<div style={{marginTop:7,borderTop:"1px solid #1a2535",paddingTop:6}}><div style={{fontSize:8,color:"#253347",letterSpacing:".2em",marginBottom:5}}>라운드 수</div><div style={{display:"flex",gap:4}}>{ROUNDS_OPT.map(r=><button key={r} className={`pill ${rounds===r?"on":""}`} onClick={()=>setRounds(r)}>{r}R</button>)}</div></div>)}
        {selCats.length>0&&!isFL&&!isTab&&!isDB&&(<div style={{marginTop:7,borderTop:"1px solid #1a2535",paddingTop:6}}><div style={{fontSize:8,color:"#253347",letterSpacing:".2em",marginBottom:5}}>랩수 (빈칸=랜덤)</div><div style={{display:"flex",flexWrap:"wrap",gap:5}}>{selCats.map(cat=>(<div key={cat} style={{display:"flex",alignItems:"center",gap:4}}><span style={{fontSize:9,color:"#475569"}}>{MOVEMENTS[cat].label}</span><input className="rinp" type="number" min="1" max="50" placeholder="?" value={manReps[cat]||""} onChange={e=>setManReps(p=>({...p,[cat]:e.target.value}))}/></div>))}</div></div>)}
      </div>
    )}

    {error&&<div style={{marginBottom:8,padding:"7px 10px",background:"#1c0a0a",border:"1px solid #7f1d1d",borderRadius:8,color:"#fca5a5",fontFamily:"'IBM Plex Mono',monospace",fontSize:10}}>⚠️ {error}</div>}

    <button className="gen" style={{background:TYPE_COLOR[wodType]||"#ef4444"}} onClick={handleGenerate} disabled={loading||(mode==="manual"&&!isNamed&&!selCats.length)||(isNamed&&namedIdx===null)}>
      {loading?"⏳ 생성 중...":isNamed?"📋 와드 불러오기":mode==="ai"?"🤖 AI WOD 생성":"✅ WOD 빌드"}
    </button>

    {loading&&<LoadingWOD/>}

    {/* 결과 */}
    {wod&&!loading&&(
      <div className="fi" style={{marginTop:12,display:"grid",gridTemplateColumns:"1fr auto",gap:10}}>
        <div className="card">
          <div style={{display:"flex",justifyContent:"space-between",alignItems:"flex-start",marginBottom:10}}>
            <div>
              {wod.namedTitle
                ?<><div style={{fontFamily:"'Bebas Neue'",fontSize:21,color:"#a855f7",letterSpacing:".05em"}}>{wod.namedTitle} <span style={{fontSize:9,fontFamily:"'IBM Plex Mono',monospace",color:cc(wod.category).text}}>{wod.category}</span></div><div style={{fontSize:9,color:"#581c87",fontFamily:"'IBM Plex Mono',monospace"}}>{wod.tribute}</div></>
                :<div style={{fontFamily:"'Bebas Neue'",fontSize:21,color:TYPE_COLOR[wod.wodType],letterSpacing:".1em"}}>{wod.wodType}</div>
              }
            </div>
            <div style={{display:"flex",alignItems:"center",gap:4,flexWrap:"wrap",justifyContent:"flex-end"}}>
              {!wod.namedTitle&&<span className="tag" style={{color:LVL_COLORS[wod.level],borderColor:LVL_COLORS[wod.level]}}>{wod.level}</span>}
              {wod.time&&<span className="tag">{wod.time}분</span>}
              {wod.rounds&&isFT&&<span className="tag" style={{color:"#60a5fa",borderColor:"#1e3a5f"}}>{typeof wod.rounds==="string"?wod.rounds:`${wod.rounds}R`}</span>}
              {wod.extra?.tabata&&<span className="tag" style={{color:"#ec4899",borderColor:"#831843"}}>20s/10s×8</span>}
              {wod.extra?.forLoad&&<span className="tag" style={{color:"#eab308",borderColor:"#713f12"}}>MAX</span>}
              <button className={`sharebtn ${copied?"ok":""}`} onClick={handleShare}>{copied?"✓ 복사됨!":"🔗 공유"}</button>
            </div>
          </div>
          {isDB&&<div style={{marginBottom:7,padding:"6px 9px",background:"#1a0f00",border:"1px solid #78350f",borderRadius:6,fontSize:9,color:"#fde68a",fontFamily:"'IBM Plex Mono',monospace",lineHeight:1.8}}><b style={{color:"#f97316"}}>Death by</b>　🔒 {wod.movements[0]?.name} 매분 {wod.movements[0]?.reps}개　📈 {wod.movements[1]?.name} +1/분</div>}
          {wod.extra?.tabata&&<div style={{marginBottom:7,padding:"6px 9px",background:"#1a0015",border:"1px solid #701a75",borderRadius:6,fontSize:9,color:"#f0abfc",fontFamily:"'IBM Plex Mono',monospace"}}><b style={{color:"#e879f9"}}>Tabata</b>: 20초 운동 → 10초 휴식 × 8라운드</div>}
          {wod.extra?.forLoad&&<div style={{marginBottom:7,padding:"6px 9px",background:"#1a1500",border:"1px solid #713f12",borderRadius:6,fontSize:9,color:"#fef08a",fontFamily:"'IBM Plex Mono',monospace"}}><b style={{color:"#eab308"}}>For Load</b>: 최대 중량 도전. 충분한 워밍업 필수.</div>}
          {wod.namedDesc&&<div style={{marginBottom:9,padding:"7px 9px",background:"#0d0920",border:"1px solid #2d1b69",borderRadius:6,fontSize:9,color:"#c4b5fd",fontFamily:"'IBM Plex Mono',monospace",lineHeight:1.9,whiteSpace:"pre-line"}}>{wod.namedDesc}</div>}
          {wod.movements.map((m,i)=>(
            <div key={i} className="mrow">
              {m.reps!=null?<div className="rbadge" style={{background:TYPE_COLOR[wod.wodType]||"#ef4444"}}>{m.reps}</div>
                :isDB&&i===1?<div className="rbadge" style={{background:"#f97316",fontSize:10}}>+1/분</div>
                :wod.extra?.tabata?<div className="rbadge" style={{background:"#db2777",fontSize:9,minWidth:40}}>20s</div>
                :wod.extra?.forLoad?<div className="rbadge" style={{background:"#ca8a04",fontSize:9,minWidth:40}}>MAX</div>
                :null}
              <div style={{flex:1}}>
                <div style={{display:"flex",alignItems:"center",gap:4}}>
                  <span style={{fontFamily:"'IBM Plex Mono'",fontWeight:600,fontSize:11}}>{m.name}</span>
                  {isDB&&<span style={{fontSize:8,borderRadius:3,padding:"1px 4px",border:"1px solid",background:i===0?"#1e3a5f":"#1a0808",color:i===0?"#60a5fa":"#f87171",borderColor:i===0?"#1e40af":"#7f1d1d"}}>{i===0?"고정":"증가"}</span>}
                </div>
                {(m.weight_M??m.wM)!=null&&<div style={{fontSize:9,color:"#334155",marginTop:1}}>♂ {m.weight_M??m.wM} lbs · ♀ {m.weight_F??m.wF} lbs</div>}
              </div>
            </div>
          ))}
          {wod.rationale&&(<><button className="rat" onClick={()=>setShowRat(p=>!p)}>{showRat?"▾":"▸"} {wod.namedTitle?"와드 소개":"AI 설계 근거"} 보기</button>{showRat&&<div style={{marginTop:5,padding:"8px 9px",background:"#070d1a",border:"1px solid #1a2535",borderLeft:`3px solid ${wod.namedTitle?"#a855f7":TYPE_COLOR[wod.wodType]}`,borderRadius:5,fontSize:9,color:"#475569",fontFamily:"'IBM Plex Mono',monospace",lineHeight:1.9}}>{wod.rationale}</div>}</>)}
          <div style={{marginTop:9,paddingTop:9,borderTop:"1px solid #1a2535"}}>
            <div style={{fontSize:8,color:"#1a2535",letterSpacing:".2em",marginBottom:4}}>목표 근육</div>
            <div style={{display:"flex",flexWrap:"wrap",gap:3}}>{wod.muscles.map(m=><span key={m} className="tag" style={{color:"#ef4444",borderColor:"#7f1d1d",background:"#1a0808"}}>{m}</span>)}</div>
          </div>
        </div>
        <div className="card" style={{padding:9,display:"flex",flexDirection:"column",alignItems:"center",minWidth:168}}>
          <div style={{fontSize:8,color:"#1a2535",letterSpacing:".2em",marginBottom:3}}>근육 지도</div>
          <div style={{display:"flex",gap:3}}><BodySVG activeMuscles={wod.muscles} side="front"/><BodySVG activeMuscles={wod.muscles} side="back"/></div>
          <div style={{marginTop:5,display:"flex",alignItems:"center",gap:4,fontSize:8,fontFamily:"'IBM Plex Mono',monospace",color:"#253347"}}><span style={{display:"inline-block",width:8,height:8,borderRadius:"50%",background:"rgba(239,68,68,0.80)"}}/>활성 근육</div>
        </div>
      </div>
    )}
    <div style={{textAlign:"center",marginTop:14,fontSize:8,color:"#0d1626",letterSpacing:".2em"}}>RXD 시도 전 반드시 전문 트레이너와 상담하세요</div>
  </div>
  </div>);
}
